rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdminOwner(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isRouteOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isValidVisibility(value) {
      return value == 'private' || value == 'public';
    }

    function isValidActivityProfile(value) {
      return value == 'hiking' ||
        value == 'cycling' ||
        value == 'running';
    }

    function isValidFavoriteActivity(value) {
      return value == 'Senderismo' ||
        value == 'Ciclismo' ||
        value == 'Running';
    }

    function isValidRoutingPreference(value) {
      return value == 'shortest' ||
        value == 'fastest' ||
        value == 'mostChallenging';
    }

    function isValidBmiCategory(value) {
      return value == null ||
        value == 'underweight' ||
        value == 'normal' ||
        value == 'overweight' ||
        value == 'obesity';
    }

    function isValidActivityLevel(value) {
      return value == null ||
        value == 'low' ||
        value == 'moderate' ||
        value == 'good' ||
        value == 'high';
    }

    function isValidWellnessStatus(value) {
      return value == null ||
        value == 'saludable' ||
        value == 'mejorable' ||
        value == 'atencion';
    }

    function isValidNullableTimestamp(value) {
      return value == null || value is timestamp;
    }

    function isValidNullableNumber(value) {
      return value == null || value is number;
    }

    function isValidNullableString(value) {
      return value == null || value is string;
    }

    function hasOnlyUserFields(data) {
      return data.keys().hasOnly([
        'uid',
        'email',
        'fullName',
        'address',
        'avatarId',
        'favoriteActivity',
        'completed_routes',
        'km_counter',
        'streak_started_at',
        'streak_deadline_at',
        'createdAt',
        'updatedAt',
        'weight_kg',
        'height_cm',
        'birth_date',
        'routes_per_week_avg',
        'km_per_week_avg',
        'minutes_per_week_avg',
        'activity_consistency_score',
        'bmi',
        'bmi_category',
        'activity_level',
        'wellness_status',
        'wellness_score',
        'inference_updated_at'
      ]);
    }

    function hasRequiredUserFields(data) {
      return data.keys().hasAll([
        'uid',
        'email',
        'fullName',
        'address',
        'avatarId',
        'favoriteActivity',
        'completed_routes',
        'km_counter',
        'streak_started_at',
        'streak_deadline_at',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isValidUserPayload(data, userId) {
      return hasOnlyUserFields(data) &&
        hasRequiredUserFields(data) &&
        data.uid is string &&
        data.uid == userId &&
        data.email is string &&
        data.email.size() > 0 &&
        data.fullName is string &&
        data.fullName.size() > 0 &&
        data.fullName.size() <= 120 &&
        data.address is string &&
        data.address.size() > 0 &&
        data.address.size() <= 200 &&
        data.avatarId is int &&
        data.avatarId >= 0 &&
        data.favoriteActivity is string &&
        isValidFavoriteActivity(data.favoriteActivity) &&
        data.completed_routes is int &&
        data.completed_routes >= 0 &&
        data.km_counter is number &&
        data.km_counter >= 0 &&
        isValidNullableTimestamp(data.streak_started_at) &&
        isValidNullableTimestamp(data.streak_deadline_at) &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp &&
        isValidNullableNumber(data.weight_kg) &&
        (data.weight_kg == null ||
          (data.weight_kg >= 20 && data.weight_kg <= 300)) &&
        isValidNullableNumber(data.height_cm) &&
        (data.height_cm == null ||
          (data.height_cm >= 100 && data.height_cm <= 250)) &&
        isValidNullableTimestamp(data.birth_date) &&
        isValidNullableNumber(data.routes_per_week_avg) &&
        (data.routes_per_week_avg == null || data.routes_per_week_avg >= 0) &&
        isValidNullableNumber(data.km_per_week_avg) &&
        (data.km_per_week_avg == null || data.km_per_week_avg >= 0) &&
        isValidNullableNumber(data.minutes_per_week_avg) &&
        (data.minutes_per_week_avg == null || data.minutes_per_week_avg >= 0) &&
        isValidNullableNumber(data.activity_consistency_score) &&
        (data.activity_consistency_score == null ||
          (data.activity_consistency_score >= 0 &&
            data.activity_consistency_score <= 100)) &&
        isValidNullableNumber(data.bmi) &&
        (data.bmi == null || (data.bmi >= 0 && data.bmi <= 100)) &&
        isValidBmiCategory(data.bmi_category) &&
        isValidActivityLevel(data.activity_level) &&
        isValidWellnessStatus(data.wellness_status) &&
        isValidNullableNumber(data.wellness_score) &&
        (data.wellness_score == null ||
          (data.wellness_score >= 0 && data.wellness_score <= 100)) &&
        isValidNullableTimestamp(data.inference_updated_at);
    }

    function ownerCanEditUserFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'fullName',
        'address',
        'avatarId',
        'favoriteActivity',
        'weight_kg',
        'height_cm',
        'birth_date',
        'completed_routes',
        'km_counter',
        'routes_per_week_avg',
        'km_per_week_avg',
        'minutes_per_week_avg',
        'activity_consistency_score',
        'bmi',
        'bmi_category',
        'activity_level',
        'wellness_status',
        'wellness_score',
        'inference_updated_at',
        'streak_started_at',
        'streak_deadline_at',
        'updatedAt'
      ]);
    }

    function hasOnlyCompletedRouteEventFields(data) {
      return data.keys().hasOnly([
        'completedAt',
        'distanceKm',
        'durationMinutes',
        'createdAt'
      ]);
    }

    function hasRequiredCompletedRouteEventFields(data) {
      return data.keys().hasAll([
        'completedAt',
        'distanceKm',
        'durationMinutes',
        'createdAt'
      ]);
    }

    function isValidCompletedRouteEventPayload(data) {
      return hasOnlyCompletedRouteEventFields(data) &&
        hasRequiredCompletedRouteEventFields(data) &&
        data.completedAt is timestamp &&
        data.distanceKm is number &&
        data.distanceKm >= 0 &&
        data.durationMinutes is number &&
        data.durationMinutes >= 0 &&
        data.createdAt is timestamp;
    }

    function isValidLatLngMap(value) {
      return value is map &&
        value.keys().hasOnly(['label', 'lat', 'lon']) &&
        value.keys().hasAll(['label', 'lat', 'lon']) &&
        value.label is string &&
        value.label.size() > 0 &&
        value.lat is number &&
        value.lon is number;
    }

    function isValidBoundingBox(value) {
      return value is map &&
        value.keys().hasOnly(['south', 'west', 'north', 'east']) &&
        value.keys().hasAll(['south', 'west', 'north', 'east']) &&
        value.south is number &&
        value.west is number &&
        value.north is number &&
        value.east is number;
    }

    function isValidPreview(value) {
      return value is map &&
        value.keys().hasOnly(['centerLat', 'centerLon']) &&
        value.keys().hasAll(['centerLat', 'centerLon']) &&
        value.centerLat is number &&
        value.centerLon is number;
    }

    function hasOnlyRouteFields(data) {
      return data.keys().hasOnly([
        'ownerId',
        'title',
        'description',
        'visibility',
        'activityProfile',
        'routingPreference',
        'start',
        'end',
        'polyline',
        'pointCount',
        'totalDistanceMeters',
        'estimatedDurationSeconds',
        'elevationGainMeters',
        'boundingBox',
        'preview',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasRequiredRouteFields(data) {
      return data.keys().hasAll([
        'ownerId',
        'title',
        'description',
        'visibility',
        'activityProfile',
        'routingPreference',
        'start',
        'end',
        'polyline',
        'pointCount',
        'totalDistanceMeters',
        'estimatedDurationSeconds',
        'elevationGainMeters',
        'boundingBox',
        'preview',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isValidRoutePayload(data) {
      return hasOnlyRouteFields(data) &&
        hasRequiredRouteFields(data) &&
        data.ownerId is string &&
        data.ownerId == request.auth.uid &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 120 &&
        data.description is string &&
        data.description.size() <= 500 &&
        isValidVisibility(data.visibility) &&
        isValidActivityProfile(data.activityProfile) &&
        isValidRoutingPreference(data.routingPreference) &&
        isValidLatLngMap(data.start) &&
        isValidLatLngMap(data.end) &&
        data.polyline is string &&
        data.polyline.size() > 0 &&
        data.pointCount is int &&
        data.pointCount > 0 &&
        data.totalDistanceMeters is number &&
        data.totalDistanceMeters >= 0 &&
        data.estimatedDurationSeconds is int &&
        data.estimatedDurationSeconds >= 0 &&
        data.elevationGainMeters is number &&
        data.elevationGainMeters >= 0 &&
        isValidBoundingBox(data.boundingBox) &&
        isValidPreview(data.preview) &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow create: if isUserOwner(userId) &&
        request.resource.data.email == request.auth.token.email &&
        isValidUserPayload(request.resource.data, userId);

      allow read: if isUserOwner(userId) || isAdmin();

      allow update: if (
          isUserOwner(userId) &&
          isValidUserPayload(request.resource.data, userId) &&
          request.resource.data.uid == resource.data.uid &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.createdAt == resource.data.createdAt &&
          ownerCanEditUserFields()
        ) || (
          isAdmin() &&
          isValidUserPayload(request.resource.data, userId)
        );

      allow delete: if isUserOwner(userId) || isAdmin();

      match /completed_route_events/{eventId} {
        allow create: if isUserOwner(userId) &&
          isValidCompletedRouteEventPayload(request.resource.data);

        allow read: if isUserOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow create: if isAdminOwner(adminId) &&
        request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'role',
          'createdAt'
        ]) &&
        request.resource.data.uid == adminId &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.email is string &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role is string &&
        request.resource.data.createdAt is timestamp;

      allow read: if isAdminOwner(adminId) || isAdmin();
      allow update, delete: if isAdminOwner(adminId);
    }

    match /routes/{routeId} {
      allow create: if isSignedIn() && isValidRoutePayload(request.resource.data);

      allow read: if isSignedIn() &&
        (isRouteOwner() || resource.data.visibility == 'public' || isAdmin());

      allow update: if isRouteOwner() &&
        request.resource.data.ownerId == resource.data.ownerId &&
        isValidRoutePayload(request.resource.data);

      allow delete: if isRouteOwner() || isAdmin();
    }
  }
}
