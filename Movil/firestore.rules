rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRouteOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isAdminOwner(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidVisibility(value) {
      return value == 'private' || value == 'public';
    }

    function isValidActivityProfile(value) {
      return value == 'hiking' ||
        value == 'cycling' ||
        value == 'running';
    }

    function isValidRoutingPreference(value) {
      return value == 'shortest' ||
        value == 'fastest' ||
        value == 'mostChallenging';
    }

    function isValidLatLngMap(value) {
      return value is map &&
        value.keys().hasOnly(['label', 'lat', 'lon']) &&
        value.keys().hasAll(['label', 'lat', 'lon']) &&
        value.label is string &&
        value.label.size() > 0 &&
        value.lat is number &&
        value.lon is number;
    }

    function isValidBoundingBox(value) {
      return value is map &&
        value.keys().hasOnly(['south', 'west', 'north', 'east']) &&
        value.keys().hasAll(['south', 'west', 'north', 'east']) &&
        value.south is number &&
        value.west is number &&
        value.north is number &&
        value.east is number;
    }

    function isValidPreview(value) {
      return value is map &&
        value.keys().hasOnly(['centerLat', 'centerLon']) &&
        value.keys().hasAll(['centerLat', 'centerLon']) &&
        value.centerLat is number &&
        value.centerLon is number;
    }

    function hasOnlyRouteFields(data) {
      return data.keys().hasOnly([
        'ownerId',
        'title',
        'description',
        'visibility',
        'activityProfile',
        'routingPreference',
        'start',
        'end',
        'polyline',
        'pointCount',
        'totalDistanceMeters',
        'estimatedDurationSeconds',
        'elevationGainMeters',
        'boundingBox',
        'preview',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasRequiredRouteFields(data) {
      return data.keys().hasAll([
        'ownerId',
        'title',
        'description',
        'visibility',
        'activityProfile',
        'routingPreference',
        'start',
        'end',
        'polyline',
        'pointCount',
        'totalDistanceMeters',
        'estimatedDurationSeconds',
        'elevationGainMeters',
        'boundingBox',
        'preview',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isValidRoutePayload(data) {
      return hasOnlyRouteFields(data) &&
        hasRequiredRouteFields(data) &&
        data.ownerId is string &&
        data.ownerId == request.auth.uid &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 120 &&
        data.description is string &&
        data.description.size() <= 500 &&
        isValidVisibility(data.visibility) &&
        isValidActivityProfile(data.activityProfile) &&
        isValidRoutingPreference(data.routingPreference) &&
        isValidLatLngMap(data.start) &&
        isValidLatLngMap(data.end) &&
        data.polyline is string &&
        data.polyline.size() > 0 &&
        data.pointCount is int &&
        data.pointCount > 0 &&
        data.totalDistanceMeters is number &&
        data.totalDistanceMeters >= 0 &&
        data.estimatedDurationSeconds is int &&
        data.estimatedDurationSeconds >= 0 &&
        data.elevationGainMeters is number &&
        data.elevationGainMeters >= 0 &&
        isValidBoundingBox(data.boundingBox) &&
        isValidPreview(data.preview);
    }

    function hasOnlyPublicUserProfileFields(data) {
      return data.keys().hasOnly([
        'uid',
        'fullName',
        'avatarId',
        'favoriteActivity',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasRequiredPublicUserProfileFields(data) {
      return data.keys().hasAll([
        'uid',
        'fullName',
        'avatarId',
        'favoriteActivity',
        'updatedAt'
      ]);
    }

    function isValidPublicUserProfilePayload(data, userId) {
      return hasOnlyPublicUserProfileFields(data) &&
        hasRequiredPublicUserProfileFields(data) &&
        data.uid is string &&
        data.uid == userId &&
        data.fullName is string &&
        data.fullName.size() > 0 &&
        data.fullName.size() <= 120 &&
        data.avatarId is int &&
        data.avatarId >= 0 &&
        data.favoriteActivity is string &&
        data.favoriteActivity.size() > 0 &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        data.updatedAt is timestamp;
    }

    function hasOnlyCompletedRouteEventFields(data) {
      return data.keys().hasOnly([
        'completedAt',
        'distanceKm',
        'durationMinutes',
        'createdAt'
      ]);
    }

    function hasRequiredCompletedRouteEventFields(data) {
      return data.keys().hasAll([
        'completedAt',
        'distanceKm',
        'durationMinutes',
        'createdAt'
      ]);
    }

    function isValidCompletedRouteEventPayload(data) {
      return hasOnlyCompletedRouteEventFields(data) &&
        hasRequiredCompletedRouteEventFields(data) &&
        data.completedAt is timestamp &&
        data.distanceKm is number &&
        data.distanceKm >= 0 &&
        data.durationMinutes is number &&
        data.durationMinutes >= 0 &&
        data.createdAt is timestamp;
    }

    function hasOnlySavedPublicRouteFields(data) {
      return data.keys().hasOnly([
        'savedByUserId',
        'sourceRouteId',
        'sourceOwnerId',
        'sourceOwnerName',
        'title',
        'description',
        'visibility',
        'activityProfile',
        'routingPreference',
        'start',
        'end',
        'polyline',
        'pointCount',
        'totalDistanceMeters',
        'estimatedDurationSeconds',
        'elevationGainMeters',
        'boundingBox',
        'preview',
        'sourceRouteCreatedAt',
        'sourceRouteUpdatedAt',
        'savedAt',
        'createdAt',
        'updatedAt'
      ]);
    }

    function hasRequiredSavedPublicRouteFields(data) {
      return data.keys().hasAll([
        'savedByUserId',
        'sourceRouteId',
        'sourceOwnerId',
        'sourceOwnerName',
        'title',
        'description',
        'visibility',
        'activityProfile',
        'routingPreference',
        'start',
        'end',
        'polyline',
        'pointCount',
        'totalDistanceMeters',
        'estimatedDurationSeconds',
        'elevationGainMeters',
        'boundingBox',
        'preview',
        'savedAt',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isValidSavedPublicRoutePayload(data) {
      return hasOnlySavedPublicRouteFields(data) &&
        hasRequiredSavedPublicRouteFields(data) &&
        data.savedByUserId is string &&
        data.savedByUserId == request.auth.uid &&
        data.sourceRouteId is string &&
        data.sourceRouteId.size() > 0 &&
        data.sourceOwnerId is string &&
        data.sourceOwnerId.size() > 0 &&
        data.sourceOwnerId != request.auth.uid &&
        data.sourceOwnerName is string &&
        data.sourceOwnerName.size() > 0 &&
        data.title is string &&
        data.title.size() > 0 &&
        data.title.size() <= 120 &&
        data.description is string &&
        data.description.size() <= 500 &&
        data.visibility == 'public' &&
        isValidActivityProfile(data.activityProfile) &&
        isValidRoutingPreference(data.routingPreference) &&
        isValidLatLngMap(data.start) &&
        isValidLatLngMap(data.end) &&
        data.polyline is string &&
        data.polyline.size() > 0 &&
        data.pointCount is int &&
        data.pointCount > 0 &&
        data.totalDistanceMeters is number &&
        data.totalDistanceMeters >= 0 &&
        data.estimatedDurationSeconds is int &&
        data.estimatedDurationSeconds >= 0 &&
        data.elevationGainMeters is number &&
        data.elevationGainMeters >= 0 &&
        isValidBoundingBox(data.boundingBox) &&
        isValidPreview(data.preview) &&
        (!('sourceRouteCreatedAt' in data) || data.sourceRouteCreatedAt == null || data.sourceRouteCreatedAt is timestamp) &&
        (!('sourceRouteUpdatedAt' in data) || data.sourceRouteUpdatedAt == null || data.sourceRouteUpdatedAt is timestamp) &&
        data.savedAt is timestamp &&
        data.createdAt is timestamp &&
        data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow create: if isUserOwner(userId);
      allow read: if isUserOwner(userId) || isAdmin();
      allow update, delete: if isUserOwner(userId) || isAdmin();

      match /completed_route_events/{eventId} {
        allow create: if isUserOwner(userId) &&
          isValidCompletedRouteEventPayload(request.resource.data);
        allow read: if isUserOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    match /public_user_profiles/{userId} {
      allow create: if isUserOwner(userId) &&
        isValidPublicUserProfilePayload(request.resource.data, userId);
      allow read: if isSignedIn();
      allow update: if (isUserOwner(userId) || isAdmin()) &&
        isValidPublicUserProfilePayload(request.resource.data, userId);
      allow delete: if isUserOwner(userId) || isAdmin();
    }

    match /admins/{adminId} {
      allow create: if isAdmin() &&
        request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'role',
          'createdAt'
        ]) &&
        request.resource.data.uid == adminId &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.email is string &&
        request.resource.data.role is string &&
        (
          request.resource.data.role == 'admin' ||
          request.resource.data.role == 'super_admin'
        );

      allow read: if isAdminOwner(adminId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /routes/{routeId} {
      allow create: if isSignedIn() && isValidRoutePayload(request.resource.data);

      allow read: if isSignedIn() &&
        (isRouteOwner() || resource.data.visibility == 'public' || isAdmin());

      allow update: if isRouteOwner() &&
        request.resource.data.ownerId == resource.data.ownerId &&
        isValidRoutePayload(request.resource.data);

      allow delete: if isRouteOwner();
    }

    match /saved_public_routes/{savedRouteId} {
      allow create: if isSignedIn() &&
        isValidSavedPublicRoutePayload(request.resource.data);

      allow read: if isSignedIn() &&
        (resource.data.savedByUserId == request.auth.uid || isAdmin());

      allow update: if isAdmin() &&
        isValidSavedPublicRoutePayload(request.resource.data);

      allow delete: if isSignedIn() &&
        (resource.data.savedByUserId == request.auth.uid || isAdmin());
    }
  }
}
